      "/sys/",
      "C:\\Windows",
      "C:\\Users",
      "%APPDATA%",
      "/root/",
      "/home/",
      "~/"
    ],
    "allowed_extensions": [
      ".txt",
      ".md",
      ".pdf",
      ".csv",
      ".json",
      ".py",
      ".js",
      ".ts",
      ".rs",
      ".go",
      ".html",
      ".css",
      ".yaml",
      ".toml"
    ]
  },

  "behavioral": {
    "enabled": true,
    "max_prompt_length": 4000,
    "max_tokens_per_minute": 8000,
    "max_requests_per_minute": 30,
    "repeated_block_threshold": 3
